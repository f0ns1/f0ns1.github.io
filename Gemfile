source "https://rubygems.org"

# Tema incluido en el repo (_layouts, _includes, _sass).
gem "jekyll", "~> 3.9"
gem "jekyll-seo-tag", "~> 2.8"
gem "kramdown-parser-gfm", "~> 1.1"

# Ruby 3.x ya no incluye webrick; necesario para `jekyll serve`
gem "webrick", "~> 1.8"

# public_suffix 7.x requiere Ruby >= 3.2 (compatible con Docker jekyll/jekyll)
gem "public_suffix", "~> 6.0"
